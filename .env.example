# Environment Variables for Production Deployment
# Copy this file to .env and fill in your values

# API Security
RAG_API_KEY=sk-your-super-secret-key-here

# Ollama Configuration
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_GPU=1  # 1 to enable GPU, 0 for CPU only

# Database
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_docs

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/rag_pipeline.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Caching
CACHE_ENABLED=true
CACHE_MAX_SIZE=1000
CACHE_TTL_SECONDS=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Model Configuration
EMBEDDING_MODEL=all-mpnet-base-v2
EMBEDDING_DEVICE=auto  # auto, cuda, mps, cpu
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CROSS_ENCODER_DEVICE=auto
LLM_MODEL=llama3

# Retrieval Weights (sum should be ~1.0)
RETRIEVAL_ALPHA=0.6    # Cross-encoder weight
RETRIEVAL_BETA=0.3     # Dense similarity weight
RETRIEVAL_GAMMA=0.1    # TF-IDF weight

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# Monitoring
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Development
DEBUG=false
RELOAD=false
